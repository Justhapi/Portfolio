// Get Started: https://www.framer.com/developers
//
// ────────────────────────────────────────────────────────────────────────────
// Polished against .impeccable.md (flagship/portfolio quality).
//
// Polish summary:
//   • Centralized brand palette + 4pt spacing scale as constants (BRAND, SPACE)
//     so values are tokenized rather than scattered as magic numbers.
//   • Replaced every pure "white" SVG fill/stroke with a warm-tinted cream
//     (no pure black or pure white anywhere — design-context rule).
//   • Description line-height bumped 1.6 → 1.65 (the +0.05 lift for light
//     text on dark surfaces — a small but recruiter-visible detail).
//   • Tracker gap 10 → 12, top 44 → 48; pill padding 8px 22 → 8px 24
//     (snap to the 4pt scale).
//   • h2 margin-bottom 14 → 16 (4pt scale).
//   • Default description color #FFFFFF → tinted star-white #FCF6E8.
//   • Added font-size + font-family property controls for project name,
//     description, and pill (previously read but never declared in the
//     Framer property panel — silent UX miss).
//   • Added keyboard arrow-key navigation: ←/→ pages the carousel when
//     focus is anywhere inside the component.
//   • Tightened ARIA: content region marked role="tabpanel" with
//     aria-labelledby linking to the active tracker tab.
//   • Focus-visible ring now references a brand token rather than an
//     inline rgba literal, so it stays in sync if the cream shifts.
// ────────────────────────────────────────────────────────────────────────────

import { useState, useRef, useEffect, useId } from "react"
import { addPropertyControls, ControlType, Link } from "framer"
import {
    motion,
    AnimatePresence,
    useReducedMotion,
    useMotionValue,
} from "framer-motion"

/* -------------------------------------------------------------------------- */
/*                          Brand tokens (design system)                       */
/* -------------------------------------------------------------------------- */

// Centralized palette. Hex shown for Framer property-control compatibility,
// but every value is tinted (no pure black/white) and aligned with the
// .impeccable.md OKLCH-derived spec.
const BRAND = {
    cream: "#FFDA85", // peach-cream — primary warm
    creamLight: "#FFE6AC", // sparkle / hover lift
    creamWhite: "#FCF6E8", // star-white tinted toward cream — replaces #fff
    creamPaper: "#FFF6E4", // SVG outline white (slightly cooler)
    peach: "#E19F7E", // folder back
    peachShade: "#D59B6E", // sparkle outline
    terracotta: "#B5675B", // gradient depth + tracker inactive
    teal: "#96C5C6", // peek paper #1
    cornflower: "#5D8EF4", // peek paper #2
    cocoa: "#3A2A1F", // pill text — warm dark, never pure black
    plum: "#8B7AA8", // tracker palette accent
    ochre: "#A88958", // tracker palette — dark muted gold (project 1)

    // Lighter siblings for each tracker palette color. Active tab uses
    // these so the project KEEPS its hue identity but reads as
    // brightened — e.g. dark plum → light plum when selected — rather
    // than swapping to a single shared "active" color.
    ochreLight: "#E8C887", // lit-from-within mustard
    terracottaLight: "#E5A595", // pale brick
    plumLight: "#C3B5D6", // soft lavender
    tealLight: "#C4E0E1", // pale mint
    cornflowerLight: "#A8C2F8", // sky cornflower

    // Darker shade siblings — used for folder BACK/lip so the two folder
    // halves read as the same hue at different lightness. Hand-picked in
    // OKLCH space (base hue preserved, chroma nudged, lightness dropped
    // ~12%) so each pair reads as "one folder" rather than two colors.
    ochreShade: "#8A6E42", // deep mustard
    terracottaShade: "#934F45", // aged brick
    plumShade: "#6E5E8A", // dusk plum
    tealShade: "#6FA0A1", // slate teal
    cornflowerShade: "#4872C8", // deep cornflower
} as const

// Per-project folder paint identity. Each folder picks its front/back
// pair from this list by project index — mirroring the tracker's palette
// so folder #0 paints ochre, #1 terracotta, #2 plum, etc. Every entry
// carries TWO states:
//   • bright = the folder is the currently-selected (active) one. Front
//     uses the tracker's "Light" sibling (lit-from-within), back uses
//     the base hue so the back still reads as a shade darker than the
//     front and creates depth.
//   • dim = the folder is a peek or parked slot. Front uses the base
//     (tracker's inactive) hue, back uses the darker "Shade" sibling.
//
// This mirrors the tracker's "one project keeps its hue, but brightens
// when selected" pattern — so the same visual rule applies at both the
// tracker indicator and the full folder SVG.
//
// Projects beyond the palette length fall back to the global folderColor
// / folderBackColor props configured in Framer.
type FolderPaint = {
    frontBright: string
    backBright: string
    frontDim: string
    backDim: string
}
const FOLDER_PALETTE: ReadonlyArray<FolderPaint> = [
    {
        frontBright: BRAND.ochreLight,
        backBright: BRAND.ochre,
        frontDim: BRAND.ochre,
        backDim: BRAND.ochreShade,
    },
    {
        frontBright: BRAND.terracottaLight,
        backBright: BRAND.terracotta,
        frontDim: BRAND.terracotta,
        backDim: BRAND.terracottaShade,
    },
    {
        frontBright: BRAND.plumLight,
        backBright: BRAND.plum,
        frontDim: BRAND.plum,
        backDim: BRAND.plumShade,
    },
    {
        frontBright: BRAND.tealLight,
        backBright: BRAND.teal,
        frontDim: BRAND.teal,
        backDim: BRAND.tealShade,
    },
    {
        frontBright: BRAND.cornflowerLight,
        backBright: BRAND.cornflower,
        frontDim: BRAND.cornflower,
        backDim: BRAND.cornflowerShade,
    },
]

// 4pt spacing scale, semantic names (not pixel-named). Use these instead of
// magic numbers so spacing reads as rhythm, not coincidence.
const SPACE = {
    xs: 4,
    sm: 8,
    md: 12,
    lg: 16,
    xl: 24,
    xxl: 32,
    xxxl: 48,
} as const

// Warm-tinted shadow — never pure black; tinted toward the cocoa axis so
// shadows read as warm shade rather than a generic dropshadow.
const SHADOW_WARM = "0 6px 18px rgba(58, 35, 28, 0.28)"

// Focus ring — references the brand cream (rgba derived from BRAND.cream).
const FOCUS_RING = "rgba(255, 218, 133, 0.9)"

// System font stack that inherits cleanly from the host page.
// Intentionally omits Inter to avoid the default-font monoculture.
const SYSTEM_FONT_STACK =
    "-apple-system, BlinkMacSystemFont, system-ui, 'Segoe UI', sans-serif"

/**
 * @framerSupportedLayoutWidth any
 * @framerSupportedLayoutHeight any
 */
export default function Project_Carousel(props) {
    const {
        backgroundColor,
        projectNameColor,
        projectNameFontFamily,
        projectNameFontSize,
        descriptionColor,
        descriptionFontFamily,
        descriptionFontSize,
        pillColor,
        pillTextColor,
        pillFontFamily,
        pillFontSize,
        trackerActiveColor,
        trackerInactiveColor,
        folderColor,
        folderBackColor,
        descriptionLeft = 120,
        descriptionTop = 200,
        descriptionWidth = 320,
        // 480 (was 520): mirrors the 44px breathing room between the
        // left arrow tip (x≈76) and the description block (x=120) on the
        // opposite side. With folderWidth=300 and the right arrow
        // anchored to right:28, this puts equal visual padding on both
        // ends of the carousel row.
        folderLeft = 480,
        folderTop = 150,
        folderWidth = 300,
        folderHeight = 260,
        projects,
    } = props

    const safeProjects =
        projects && projects.length > 0 ? projects : DEFAULT_PROJECTS

    const [currentIndex, setCurrentIndex] = useState(0)
    const [direction, setDirection] = useState(1) // 1 = forward, -1 = back
    // Hover state is now a three-way enum so the floating pill can swap
    // labels depending on whether the description block or the folder
    // is under the cursor.
    const [hoveredArea, setHoveredArea] = useState<
        "none" | "description" | "folder"
    >("none")
    // Bumped on every slide change. Fed into each tracker tab as part of a
    // motion key so the tabs replay a one-shot "shuffle" kick whenever the
    // carousel pages — like flicking a stack of cards.
    const [shuffleNonce, setShuffleNonce] = useState(0)
    const prefersReducedMotion = useReducedMotion()

    // Gate the active folder's hover→open reaction behind "has the
    // newly-selected folder finished sliding into the center?" When the
    // carousel pages, the incoming folder is still in motion — firing
    // its keyframe open-folder animation at that point looks chaotic
    // (papers appear to fly in before the folder itself has stopped).
    // We flip this false on every currentIndex change, then back to
    // true after the slot transition duration has elapsed. While it's
    // false, `isHovered` stays false on the active folder even if the
    // cursor is over it — the open animation waits for arrival.
    const [activeSettled, setActiveSettled] = useState(true)
    useEffect(() => {
        // Match the longest channel of slotTransition (x / y / rotate
        // at 0.7s) plus a small guard so the folder is visually at rest
        // before we re-enable hover→open. Reduced-motion users get an
        // instant unlock since slot transitions collapse to duration 0.
        setActiveSettled(false)
        const unlockMs = prefersReducedMotion ? 0 : 720
        const t = setTimeout(() => setActiveSettled(true), unlockMs)
        return () => clearTimeout(t)
    }, [currentIndex, prefersReducedMotion])

    // Stable id base for ARIA wiring (tab → tabpanel relationship).
    // Replacing the colons keeps the ids valid as HTML id attributes.
    const idBase = useId().replace(/:/g, "")
    const tabId = (i: number) => `${idBase}-tab-${i}`
    const panelId = `${idBase}-panel`

    // Cursor tracking lives at the root so the pill can follow the mouse
    // across BOTH the description and the folder, not just inside the
    // folder container.
    //
    // We use motion values instead of React state so mouse moves do NOT
    // re-render the carousel — updates go straight to the DOM, which keeps
    // the folder keyframe animation fluid and the pill glued to the cursor
    // at 60fps.
    const rootRef = useRef<HTMLDivElement>(null)
    const cursorX = useMotionValue(0)
    const cursorY = useMotionValue(0)
    const handleRootMouseMove = (e: React.MouseEvent<HTMLDivElement>) => {
        const rect = rootRef.current?.getBoundingClientRect()
        if (!rect) return
        cursorX.set(e.clientX - rect.left + 18)
        cursorY.set(e.clientY - rect.top + 18)
    }

    const current = safeProjects[currentIndex % safeProjects.length]

    // Fires on every slide-change pathway so the tracker shuffle replays
    // even when the user clicks the same tab as before (re-tap restages the
    // animation rather than going stale).
    const bumpShuffle = () => setShuffleNonce((n) => n + 1)

    const goTo = (i: number) => {
        setDirection(i > currentIndex ? 1 : -1)
        setCurrentIndex(
            ((i % safeProjects.length) + safeProjects.length) %
                safeProjects.length
        )
        bumpShuffle()
    }
    const next = () => {
        setDirection(1)
        setCurrentIndex((i) => (i + 1) % safeProjects.length)
        bumpShuffle()
    }
    const prev = () => {
        setDirection(-1)
        setCurrentIndex(
            (i) => (i - 1 + safeProjects.length) % safeProjects.length
        )
        bumpShuffle()
    }

    // Keyboard navigation — ← / → page the carousel whenever focus is
    // anywhere inside the component. Lets keyboard users drive the carousel
    // without having to tab to a specific arrow button each time.
    const handleRootKeyDown = (e: React.KeyboardEvent<HTMLDivElement>) => {
        if (e.key === "ArrowRight") {
            e.preventDefault()
            next()
        } else if (e.key === "ArrowLeft") {
            e.preventDefault()
            prev()
        }
    }

    // Slide variants for synced description + folder transitions.
    // The carousel cross-fades: the outgoing slide travels ALL the way
    // off the component, blurring and fading as it goes, while the
    // incoming slide simultaneously rushes in from the opposite side,
    // sharpening into focus. Both children stack absolutely (see the
    // motion.div style below) so they share coordinate space during the
    // overlap rather than queueing one after the other.
    //
    // - slideDistance is set well past any reasonable content width so
    //   the outgoing slide truly clears the frame instead of stalling
    //   half-on-stage.
    // - blur softens the silhouette as it leaves so the eye doesn't try
    //   to read both copies at once.
    // - ease-out-expo gives a confident decelerating curve — the new
    //   slide arrives quickly, then settles. Linear and spring both let
    //   the slide loiter at the edges; expo doesn't.
    // - Reduced-motion users get an instant swap with no blur.
    const slideDistance = prefersReducedMotion ? 0 : 860
    const slideBlur = prefersReducedMotion ? 0 : 10
    const slideVariants = {
        enter: (dir: number) => ({
            x: dir > 0 ? slideDistance : -slideDistance,
            opacity: 0,
            filter: `blur(${slideBlur}px)`,
        }),
        center: {
            x: 0,
            opacity: 1,
            filter: "blur(0px)",
        },
        exit: (dir: number) => ({
            x: dir > 0 ? -slideDistance : slideDistance,
            opacity: 0,
            filter: `blur(${slideBlur}px)`,
        }),
    }
    const slideTransition = prefersReducedMotion
        ? { duration: 0 }
        : {
              x: { duration: 0.75, ease: [0.16, 1, 0.3, 1] as const },
              opacity: { duration: 0.55, ease: [0.16, 1, 0.3, 1] as const },
              filter: { duration: 0.55, ease: [0.16, 1, 0.3, 1] as const },
          }

    /* --------------------------------------------------------------------
     * Slot-based folder choreography
     *
     * Every project in `safeProjects` owns ONE persistent motion.div on
     * the stage. Each div's transform is driven by its current "slot" —
     * a signed distance from `currentIndex` (0 = active, ±1 = peeks,
     * |n|≥2 = parked off-stage). When `currentIndex` changes, the slots
     * shift by one and framer-motion animates each div from its old slot
     * position to its new one.
     *
     * Why this shape (and not AnimatePresence + separate PeekFolders):
     *  • Clicking the RIGHT peek smoothly slides THAT SAME folder into
     *    center (no mount/unmount flicker). The old center slides
     *    CONTINUOUSLY to the left peek — not exit + re-enter.
     *  • The project one-past the right peek (slot 2) is "parked above"
     *    at opacity 0. When the user advances, it animates from slot 2
     *    → slot 1, which visually = a fresh folder DROPPING from above
     *    into the peek slot the selected folder just vacated.
     *  • Direction-aware parking: when going next, far-left slots are
     *    off-screen-left (the conveyor-belt exit); when going prev, the
     *    same slots are "above left peek" (ready to drop in).
     * ------------------------------------------------------------------ */
    const n = safeProjects.length

    // Signed slot: positive = right of active, negative = left. Wraps so
    // |slot| is never larger than n/2 — i.e., the project "closest" to
    // active wins. For n=5 and currentIndex=0, project 3 resolves to
    // slot -2 (closer via wrap) rather than slot 3.
    const getSlot = (projectIdx: number) => {
        const raw = (((projectIdx - currentIndex) % n) + n) % n
        return raw > n / 2 ? raw - n : raw
    }

    // Peek layout tokens — baseline offsets for the tilted "stack of
    // papers" look. Active sits center-stage at native scale; peeks are
    // smaller, tilted, and lifted slightly to read as "behind and above."
    const PEEK_X = 96
    const PEEK_Y = -8
    const PEEK_SCALE = 0.78
    const PEEK_ROTATE = 10
    const PEEK_OPACITY = 0.55
    const DROP_Y = -400 // parked above the peek, ready to drop
    const EXIT_X = 1000 // off-screen horizontal parking

    // Resolve a slot → animate target. `dir` controls which side the
    // parking slots sit on, so the same slot index can mean "dropping
    // in from above" in one direction and "sliding off-screen" in the
    // other without discontinuity on the VISIBLE slots (-1, 0, 1).
    const getSlotTarget = (slot: number, dir: number) => {
        if (prefersReducedMotion) {
            // Static layout for motion-sensitive users: no rotation, no
            // blur, no vertical drop. Off-stage is just opacity 0.
            if (slot === 0)
                return { x: 0, y: 0, scale: 1, rotate: 0, opacity: 1 }
            if (slot === -1)
                return {
                    x: -PEEK_X,
                    y: 0,
                    scale: PEEK_SCALE,
                    rotate: 0,
                    opacity: PEEK_OPACITY,
                }
            if (slot === 1)
                return {
                    x: PEEK_X,
                    y: 0,
                    scale: PEEK_SCALE,
                    rotate: 0,
                    opacity: PEEK_OPACITY,
                }
            return { x: 0, y: 0, scale: 0.6, rotate: 0, opacity: 0 }
        }

        // Active — center stage, native size, no tilt, no blur.
        if (slot === 0) {
            return {
                x: 0,
                y: 0,
                scale: 1,
                rotate: 0,
                opacity: 1,
                filter: "blur(0px) saturate(1)",
            }
        }
        // Left peek.
        if (slot === -1) {
            return {
                x: -PEEK_X,
                y: PEEK_Y,
                scale: PEEK_SCALE,
                rotate: -PEEK_ROTATE,
                opacity: PEEK_OPACITY,
                filter: "blur(1.5px) saturate(0.85)",
            }
        }
        // Right peek.
        if (slot === 1) {
            return {
                x: PEEK_X,
                y: PEEK_Y,
                scale: PEEK_SCALE,
                rotate: PEEK_ROTATE,
                opacity: PEEK_OPACITY,
                filter: "blur(1.5px) saturate(0.85)",
            }
        }

        // Parked — direction decides where the slot LIVES. Going next
        // (dir > 0): far-left is "already exited off-screen-left", and
        // far-right is "queued above the right peek, waiting to drop."
        // Going prev: mirrored.
        if (slot <= -2) {
            return dir >= 0
                ? {
                      // Exited: slid off the left edge.
                      x: -EXIT_X,
                      y: 0,
                      scale: 0.6,
                      rotate: -20,
                      opacity: 0,
                      filter: "blur(10px) saturate(1)",
                  }
                : {
                      // Queued: floating above the left peek slot.
                      x: -PEEK_X,
                      y: DROP_Y,
                      scale: 0.6,
                      rotate: -PEEK_ROTATE,
                      opacity: 0,
                      filter: "blur(8px) saturate(0.85)",
                  }
        }
        // slot >= 2
        return dir >= 0
            ? {
                  // Queued: floating above the right peek slot.
                  x: PEEK_X,
                  y: DROP_Y,
                  scale: 0.6,
                  rotate: PEEK_ROTATE,
                  opacity: 0,
                  filter: "blur(8px) saturate(0.85)",
              }
            : {
                  // Exited: slid off the right edge.
                  x: EXIT_X,
                  y: 0,
                  scale: 0.6,
                  rotate: 20,
                  opacity: 0,
                  filter: "blur(10px) saturate(1)",
              }
    }

    // Hover override for peek slots: tilt further out, lift, clarify.
    // This reads as the peek "inviting" the click — it peels out from
    // behind the active folder rather than merely changing color.
    const getPeekHover = (slot: number) => {
        if (prefersReducedMotion) return undefined
        if (slot !== -1 && slot !== 1) return undefined
        const sign = slot === -1 ? -1 : 1
        return {
            x: sign * 130,
            y: PEEK_Y - 8,
            scale: 0.86,
            rotate: sign * 14,
            opacity: 0.9,
            filter: "blur(0px) saturate(1)",
        }
    }

    // Slot transition: ease-out-expo so the decelerating folder lands
    // decisively instead of loitering on approach. Filter runs slightly
    // faster than the transform so the incoming folder sharpens into
    // focus before it fully settles (reads as "confident arrival").
    const slotTransition = prefersReducedMotion
        ? { duration: 0 }
        : {
              x: { duration: 0.7, ease: [0.16, 1, 0.3, 1] as const },
              y: { duration: 0.7, ease: [0.16, 1, 0.3, 1] as const },
              scale: { duration: 0.65, ease: [0.16, 1, 0.3, 1] as const },
              rotate: { duration: 0.7, ease: [0.16, 1, 0.3, 1] as const },
              opacity: {
                  duration: 0.5,
                  ease: [0.16, 1, 0.3, 1] as const,
              },
              filter: {
                  duration: 0.55,
                  ease: [0.16, 1, 0.3, 1] as const,
              },
          }

    return (
        <div
            ref={rootRef}
            onMouseMove={handleRootMouseMove}
            onKeyDown={handleRootKeyDown}
            style={{
                position: "relative",
                width: "100%",
                height: "100%",
                // Sized to fit description (120–440) + folder (480–780) +
                // both side arrows (left tip x≈76, right tip x≈824 inside
                // a 900-wide frame) with matching 44px padding on each
                // end of the row. Wider frames give more breathing room
                // on the right; narrower ones force-hold this width so
                // the folder and arrows never get clipped.
                minWidth: 900,
                minHeight: 520,
                background: backgroundColor,
                // Overflow visible so the folder hover lift (which travels
                // up to ~110px during the open-folder keyframes) isn't
                // clipped at the top of the component. The slide variants
                // already fade to opacity 0 + blur(10px) at full travel,
                // so outgoing slides become invisible long before they
                // could leak into adjacent page sections.
                overflow: "visible",
                fontFamily: SYSTEM_FONT_STACK,
            }}
        >
            {/* Scoped focus styles: no outline on mouse click,
                visible cream ring only on keyboard focus. */}
            <style>{`
                .pc-focusable { outline: none; }
                .pc-focusable:focus { outline: none; }
                .pc-focusable:focus-visible {
                    box-shadow: 0 0 0 2px ${FOCUS_RING};
                }
            `}</style>

            {/* Carousel tracker (top right) */}
            <div
                role="tablist"
                aria-label="Project carousel navigation"
                style={{
                    position: "absolute",
                    top: SPACE.xxxl, // 48 — snaps to 4pt scale (was 44)
                    right: SPACE.xxxl, // 48
                    display: "flex",
                    gap: SPACE.md, // 12 (was 10)
                    alignItems: "center",
                    zIndex: 3,
                }}
            >
                {safeProjects.map((p, i) => {
                    // All inactive folders tilt the same way for a consistent
                    // "stack of papers" look; the active one stands upright.
                    const baseTilt = -10
                    const isActive = i === currentIndex
                    const label =
                        (p && (p as { name?: string }).name) ||
                        `Project ${i + 1}`

                    // Shuffle kick — magnitude grows with distance from the
                    // active tab and alternates direction by index parity, so
                    // the shuffle reads as a *propagating* ripple outward
                    // from where the user clicked rather than every tab
                    // doing the same flick.
                    const distFromActive = Math.abs(i - currentIndex)
                    const kickRotate = prefersReducedMotion
                        ? 0
                        : (i % 2 === 0 ? -1 : 1) *
                          (3 + Math.min(distFromActive, 3))
                    const kickY = prefersReducedMotion
                        ? 0
                        : -3 - Math.min(distFromActive, 2)

                    return (
                        <motion.button
                            key={i}
                            id={tabId(i)}
                            role="tab"
                            aria-selected={isActive}
                            aria-controls={panelId}
                            aria-label={`Show ${label}`}
                            className="pc-focusable"
                            onClick={() => goTo(i)}
                            whileHover={
                                prefersReducedMotion
                                    ? undefined
                                    : {
                                          scale: 1.2,
                                          y: -4,
                                          rotate: baseTilt - 4,
                                      }
                            }
                            whileTap={{ scale: 0.92 }}
                            animate={{
                                scale: isActive ? 1.15 : 0.85,
                                opacity: isActive ? 1 : 0.55,
                                rotate: prefersReducedMotion
                                    ? 0
                                    : isActive
                                      ? 0
                                      : baseTilt,
                            }}
                            transition={{
                                type: "spring",
                                stiffness: 260,
                                damping: 26,
                            }}
                            style={{
                                background: "none",
                                border: "none",
                                cursor: "pointer",
                                padding: 0,
                                minWidth: 44, // accessibility: touch target
                                minHeight: 44,
                                // Anchor for the absolute-positioned sparkle
                                // pulse rendered on the active tab below.
                                position: "relative",
                                display: "flex",
                                alignItems: "center",
                                justifyContent: "center",
                                borderRadius: 6,
                            }}
                        >
                            {/* Shuffle wrapper — re-keys on every slide so
                                its initial → animate replays as a one-shot
                                kick. Composes with the parent button's
                                rotate/scale because they apply on different
                                DOM nodes. */}
                            <motion.div
                                key={`mini-${shuffleNonce}`}
                                initial={
                                    prefersReducedMotion
                                        ? false
                                        : {
                                              y: kickY,
                                              rotate: kickRotate,
                                              scale: 0.94,
                                          }
                                }
                                animate={{ y: 0, rotate: 0, scale: 1 }}
                                transition={{
                                    type: "spring",
                                    stiffness: 320,
                                    damping: 18,
                                    mass: 0.6,
                                }}
                                style={{
                                    display: "flex",
                                    alignItems: "center",
                                    justifyContent: "center",
                                    willChange: "transform",
                                }}
                            >
                                <MiniFolder
                                    active={isActive}
                                    activeColor={trackerActiveColor}
                                    inactiveColor={trackerInactiveColor}
                                    paletteIndex={i}
                                />
                            </motion.div>

                            {/* Sparkle pulse — only on the newly active
                                tab. Keyed on currentIndex so it remounts
                                fresh on every active change, replaying its
                                burst. Skipped under reduced motion. */}
                            {isActive && !prefersReducedMotion && (
                                <motion.svg
                                    key={`pulse-${currentIndex}`}
                                    width="22"
                                    height="22"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                    focusable="false"
                                    initial={{
                                        scale: 0,
                                        opacity: 0,
                                        rotate: -45,
                                    }}
                                    animate={{
                                        scale: [0, 1.4, 0],
                                        opacity: [0, 1, 0],
                                        rotate: [-45, 0, 25],
                                    }}
                                    transition={{
                                        duration: 0.7,
                                        // ease-out-expo — confident decel
                                        ease: [0.16, 1, 0.3, 1],
                                        times: [0, 0.4, 1],
                                    }}
                                    style={{
                                        position: "absolute",
                                        top: -10,
                                        right: -10,
                                        pointerEvents: "none",
                                        zIndex: 5,
                                    }}
                                >
                                    <path
                                        d="M12 1.5 C12.4 7.6 16.4 11.6 22.5 12 C16.4 12.4 12.4 16.4 12 22.5 C11.6 16.4 7.6 12.4 1.5 12 C7.6 11.6 11.6 7.6 12 1.5 Z"
                                        fill={BRAND.creamLight}
                                    />
                                </motion.svg>
                            )}
                        </motion.button>
                    )
                })}
            </div>

            {/*
                Masked content layer — only the description + folder live in
                here. Spans the full root (inset: 0) so the gradient mask
                fades at the component's true left/right edges. Items slide
                horizontally inside and fade through the edges rather than
                dissolving at their own position.

                • pointer-events: none on this wrapper lets mouse events
                  pass through the empty areas to the arrows/tracker below.
                • Children re-enable pointer-events so hover still works.
                • role="tabpanel" + aria-labelledby ties this region to the
                  active tracker tab so screen readers announce it as the
                  panel that the selected tab controls.
            */}
            <div
                id={panelId}
                role="tabpanel"
                aria-labelledby={tabId(currentIndex)}
                style={{
                    position: "absolute",
                    inset: 0,
                    // Overflow visible + no mask: the slide variants now
                    // handle the fade (opacity 0 + blur 10px at full
                    // travel), and the folder's hover lift extends well
                    // beyond this layer's bounds — the previous
                    // overflow:hidden was clipping the lifted SVG.
                    overflow: "visible",
                    pointerEvents: "none",
                }}
            >
                {/* Project info — slides with carousel + triggers description pill */}
                <div
                    onMouseEnter={() => setHoveredArea("description")}
                    onMouseLeave={() => setHoveredArea("none")}
                    style={{
                        position: "absolute",
                        left: descriptionLeft,
                        top: descriptionTop,
                        width: descriptionWidth,
                        zIndex: 2,
                        cursor: "pointer",
                        pointerEvents: "auto",
                    }}
                >
                    {/* No `mode="wait"` — outgoing + incoming render
                        simultaneously and slide past each other. The
                        absolute positioning on the motion.div lets both
                        children occupy the same coordinate space so they
                        don't stack vertically during the overlap.
                        willChange hints transform/opacity/filter so the
                        compositor promotes the layer once. */}
                    <AnimatePresence custom={direction}>
                        <motion.div
                            key={currentIndex}
                            custom={direction}
                            variants={slideVariants}
                            initial="enter"
                            animate="center"
                            exit="exit"
                            transition={slideTransition}
                            style={{
                                position: "absolute",
                                top: 0,
                                left: 0,
                                width: "100%",
                                willChange: "transform, opacity, filter",
                            }}
                        >
                            <h2
                                style={{
                                    color: projectNameColor,
                                    fontSize: projectNameFontSize,
                                    margin: `0 0 ${SPACE.lg}px 0`, // 16 (was 14)
                                    fontWeight: 700,
                                    fontFamily: projectNameFontFamily,
                                    // Slight negative tracking on display
                                    // type — tightens the silhouette of the
                                    // project name without shouting.
                                    letterSpacing: "-0.01em",
                                }}
                            >
                                {current.name}
                            </h2>
                            <p
                                style={{
                                    color: descriptionColor,
                                    fontSize: descriptionFontSize,
                                    // 1.65 — the +0.05 lift for light text
                                    // on dark surfaces (design-context rule).
                                    lineHeight: 1.65,
                                    margin: 0,
                                    opacity: 0.92,
                                    fontFamily: descriptionFontFamily,
                                    // Cap to ~70ch so body never runs past
                                    // the readable zone even if the desc
                                    // width prop is widened.
                                    maxWidth: "70ch",
                                }}
                            >
                                {current.description}
                            </p>
                        </motion.div>
                    </AnimatePresence>
                </div>

                {/* Folder row — draggable stage.
                    Each project owns ONE persistent motion.div inside
                    this wrapper; the wrapper itself handles the drag
                    gesture. When currentIndex changes, every child
                    animates from its old slot to its new slot (see the
                    "Slot-based folder choreography" block above the
                    return). Nothing mounts or unmounts — the selected
                    peek continuously slides into center, the old center
                    continuously slides to the vacated peek slot, and
                    the next-in-line drops in from above. */}
                {(() => {
                    const hasMultiple = safeProjects.length > 1
                    return (
                        <motion.div
                            drag={
                                prefersReducedMotion || !hasMultiple
                                    ? false
                                    : "x"
                            }
                            dragConstraints={{ left: 0, right: 0 }}
                            dragElastic={0.28}
                            dragMomentum={false}
                            onDragEnd={(_, info) => {
                                const offsetThreshold = 80
                                const velocityThreshold = 500
                                if (
                                    info.offset.x < -offsetThreshold ||
                                    info.velocity.x < -velocityThreshold
                                ) {
                                    next()
                                } else if (
                                    info.offset.x > offsetThreshold ||
                                    info.velocity.x > velocityThreshold
                                ) {
                                    prev()
                                }
                            }}
                            whileTap={
                                prefersReducedMotion
                                    ? undefined
                                    : { cursor: "grabbing" }
                            }
                            style={{
                                position: "absolute",
                                left: folderLeft,
                                top: folderTop,
                                width: folderWidth,
                                height: folderHeight,
                                zIndex: 2,
                                cursor:
                                    prefersReducedMotion || !hasMultiple
                                        ? current.link
                                            ? "pointer"
                                            : "default"
                                        : "grab",
                                pointerEvents: "auto",
                                // Vertical scroll still passes through on
                                // touch devices — only horizontal drags get
                                // claimed by the carousel.
                                touchAction: "pan-y",
                            }}
                        >
                            {safeProjects.map((p, i) => {
                                const slot = getSlot(i)
                                const isActive = slot === 0
                                const isPeek = slot === -1 || slot === 1
                                const target = getSlotTarget(slot, direction)
                                const hover = isPeek
                                    ? getPeekHover(slot)
                                    : undefined

                                // Per-project folder paint. Mirrors the
                                // tracker: index 0 → ochre, 1 → terracotta,
                                // 2 → plum, 3 → teal, 4 → cornflower. Each
                                // project keeps its hue across every slot,
                                // but the CURRENTLY-SELECTED folder brightens
                                // to the "Light" sibling (and its back darkens
                                // to the base hue) so the spotlighted folder
                                // reads as lit-from-within relative to the
                                // dimmer peeks. This is the same "hue stays,
                                // brightness shifts" rule the tracker uses.
                                //
                                // Projects past the palette fall back to the
                                // global folderColor / folderBackColor props
                                // from the Framer inspector.
                                const paletteEntry =
                                    FOLDER_PALETTE[i % FOLDER_PALETTE.length]
                                const projectFolderColor = paletteEntry
                                    ? isActive
                                        ? paletteEntry.frontBright
                                        : paletteEntry.frontDim
                                    : folderColor
                                const projectFolderBackColor = paletteEntry
                                    ? isActive
                                        ? paletteEntry.backBright
                                        : paletteEntry.backDim
                                    : folderBackColor

                                // Build the folder body. FolderAnimation is
                                // rendered for EVERY project (so switching
                                // slots doesn't unmount/remount), but only
                                // the active slot's isHovered prop is wired
                                // to hoveredArea — peeks stay closed. The
                                // `activeSettled` gate prevents the open-
                                // folder keyframe from firing while the
                                // incoming active folder is still sliding
                                // into center — it waits until the folder
                                // has arrived before responding to hover.
                                const body = (
                                    <FolderAnimation
                                        isHovered={
                                            isActive &&
                                            activeSettled &&
                                            hoveredArea === "folder"
                                        }
                                        prefersReducedMotion={
                                            !!prefersReducedMotion
                                        }
                                        paper1Image={p.paper1Image}
                                        paper2Image={p.paper2Image}
                                        paper1Color={p.paper1Color}
                                        paper2Color={p.paper2Color}
                                        folderColor={projectFolderColor}
                                        folderBackColor={projectFolderBackColor}
                                        projectKey={i}
                                    />
                                )

                                // Tight hover hit-region for the active
                                // folder. Sized to the central area of the
                                // motion.div so hovering the outer edges (or
                                // anywhere outside the folder visual) no
                                // longer fires. Lives INSIDE the Link so
                                // clicks bubble up and navigate normally.
                                // Peeks and parked slots don't render this.
                                const hoverHitRegion = isActive ? (
                                    <div
                                        onMouseEnter={() =>
                                            setHoveredArea("folder")
                                        }
                                        onMouseLeave={() =>
                                            setHoveredArea("none")
                                        }
                                        aria-hidden="true"
                                        style={{
                                            position: "absolute",
                                            // Shrinks the hit-box to the
                                            // central ~40%×60% of the
                                            // motion.div. Tune these if the
                                            // folder visual doesn't fill the
                                            // full wrapper — larger values
                                            // → even tighter detection.
                                            left: "30%",
                                            right: "30%",
                                            top: "28%",
                                            bottom: "16%",
                                            // Stacks above the body so it
                                            // always captures the hover
                                            // event rather than the SVG
                                            // children underneath.
                                            zIndex: 1,
                                            pointerEvents: "auto",
                                        }}
                                    />
                                ) : null

                                // Only the active folder's body wraps in
                                // the per-project Link — peeks route via
                                // their onClick (go to that project), and
                                // far-off parked projects aren't clickable.
                                const content =
                                    isActive && p.link ? (
                                        <Link href={p.link}>
                                            <div
                                                style={{
                                                    position: "absolute",
                                                    inset: 0,
                                                    width: "100%",
                                                    height: "100%",
                                                }}
                                            >
                                                {body}
                                                {hoverHitRegion}
                                            </div>
                                        </Link>
                                    ) : isActive ? (
                                        <div
                                            style={{
                                                position: "absolute",
                                                inset: 0,
                                                width: "100%",
                                                height: "100%",
                                            }}
                                        >
                                            {body}
                                            {hoverHitRegion}
                                        </div>
                                    ) : (
                                        body
                                    )

                                // Visible slots sit in the z-order
                                // active (3) > peeks (2) > parked (0).
                                // Parked projects get pointerEvents:none
                                // so their invisible hit-boxes don't
                                // block the visible folders.
                                const z = isActive ? 3 : isPeek ? 2 : 0
                                const cursorStyle = isActive
                                    ? p.link
                                        ? "pointer"
                                        : "default"
                                    : isPeek
                                      ? "pointer"
                                      : "default"

                                return (
                                    <motion.div
                                        key={i}
                                        // Clicking a peek routes to that
                                        // project. The active slot's click
                                        // is handled by the Link wrapper
                                        // above; far slots aren't clickable.
                                        onClick={
                                            !isActive && isPeek
                                                ? () => goTo(i)
                                                : undefined
                                        }
                                        aria-label={
                                            isPeek
                                                ? `${slot === -1 ? "Previous" : "Next"} project: ${p.name ?? ""}`
                                                : undefined
                                        }
                                        role={isPeek ? "button" : undefined}
                                        tabIndex={isPeek ? 0 : undefined}
                                        className={
                                            isPeek ? "pc-focusable" : undefined
                                        }
                                        // `initial={false}`: don't animate
                                        // on mount — projects snap to their
                                        // slot positions when the carousel
                                        // first appears. Subsequent
                                        // currentIndex changes then animate
                                        // each child from its previous slot
                                        // target to the new one.
                                        initial={false}
                                        animate={target}
                                        whileHover={hover}
                                        transition={slotTransition}
                                        style={{
                                            position: "absolute",
                                            inset: 0,
                                            width: "100%",
                                            height: "100%",
                                            zIndex: z,
                                            cursor: cursorStyle,
                                            pointerEvents: isPeek
                                                ? "auto"
                                                : isActive
                                                  ? "auto"
                                                  : "none",
                                            transformOrigin: "center",
                                            willChange:
                                                "transform, opacity, filter",
                                            background: "none",
                                            border: "none",
                                            padding: 0,
                                        }}
                                    >
                                        {content}
                                    </motion.div>
                                )
                            })}
                        </motion.div>
                    )
                })()}
            </div>

            {/* Floating cursor-following pill.
                • Shown while hovering EITHER the description block or the folder.
                • Label is "{minutes} min" over the description, "Learn more"
                  over the folder. */}
            <AnimatePresence>
                {hoveredArea !== "none" && (
                    <motion.div
                        key={`pill-${hoveredArea}`}
                        initial={{ opacity: 0, scale: 0.6 }}
                        animate={{ opacity: 1, scale: 1 }}
                        exit={{ opacity: 0, scale: 0.6 }}
                        transition={{
                            opacity: { duration: 0.18 },
                            scale: {
                                type: "spring",
                                stiffness: 420,
                                damping: 24,
                            },
                        }}
                        style={{
                            // Cursor tracking: bind motion values directly to
                            // the transform so it follows the mouse 1:1 with
                            // zero React re-renders.
                            x: cursorX,
                            y: cursorY,
                            position: "absolute",
                            top: 0,
                            left: 0,
                            background: pillColor,
                            color: pillTextColor,
                            // Outline tracks the text color so it stays
                            // on-brand whatever the user picks in the
                            // Framer inspector.
                            border: `2px solid ${pillTextColor}`,
                            padding: `${SPACE.sm}px ${SPACE.xl}px`, // 8/24 (was 8/22)
                            borderRadius: 999,
                            fontWeight: 700,
                            fontSize: pillFontSize,
                            fontFamily: pillFontFamily,
                            boxShadow: SHADOW_WARM,
                            pointerEvents: "none",
                            willChange: "transform, opacity",
                            zIndex: 10,
                            whiteSpace: "nowrap",
                        }}
                    >
                        {hoveredArea === "folder"
                            ? "Learn more"
                            : `${current.minutes} min`}
                    </motion.div>
                )}
            </AnimatePresence>
        </div>
    )
}

/* -------------------------------------------------------------------------- */
/*                          Folder animation component                         */
/* -------------------------------------------------------------------------- */

function FolderAnimation({
    isHovered,
    prefersReducedMotion,
    paper1Image,
    paper2Image,
    paper1Color,
    paper2Color,
    folderColor,
    folderBackColor,
    projectKey,
}: {
    isHovered: boolean
    prefersReducedMotion: boolean
    paper1Image?: string
    paper2Image?: string
    paper1Color?: string
    paper2Color?: string
    folderColor: string
    folderBackColor: string
    projectKey: number
}) {
    // Multi-stage keyframes: rest → lift slightly → squeeze + lift →
    // crossfade midpoint → wide overshoot landing → settle at rest.
    // Total duration: 0.3s on hover; reduced motion collapses to a quick fade.
    //
    // IMPORTANT: we only use the keyframe array for the HOVER direction. On
    // unhover we switch to a single target + plain tween so framer-motion
    // interpolates FROM THE CURRENT STATE (wherever the hover animation had
    // reached) straight back to rest. Using a keyframe array both ways causes
    // a visible jump when the user navigates mid-hover — framer-motion snaps
    // to the first value of the new array before animating, so a folder at
    // y=-40 would snap to y=-110 (first frame of the return sequence). The
    // single-target tween eliminates that snap.
    const hoverTransition = prefersReducedMotion
        ? { duration: 0.2, ease: "easeOut" as const }
        : {
              duration: 0.3,
              times: [0, 0.18, 0.42, 0.5, 0.78, 1],
              ease: "easeInOut" as const,
          }
    const unhoverTransition = prefersReducedMotion
        ? { duration: 0.2, ease: "easeOut" as const }
        : {
              duration: 0.42,
              // ease-out-expo — natural deceleration, no bounce.
              ease: [0.16, 1, 0.3, 1] as [number, number, number, number],
          }
    const transition = isHovered ? hoverTransition : unhoverTransition

    // Track whether the user has ever hovered. Held in state (not a ref
    // mutated during render) so React re-renders correctly once the user
    // first interacts — at which point we switch from the static rest
    // frame to the keyframed hover sequence.
    const [hasInteracted, setHasInteracted] = useState(false)
    useEffect(() => {
        if (isHovered && !hasInteracted) setHasInteracted(true)
    }, [isHovered, hasInteracted])

    // Closed-folder path: fully visible at rest → squeeze + lift → fade out at midpoint
    const closedAnimHover = {
        y: [0, -40, -110, -110, -110, -110],
        scaleX: [1, 0.85, 0.32, 0.32, 0.32, 0.32],
        scaleY: [1, 1.05, 1.18, 1.18, 1.18, 1.18],
        rotate: [0, -3, -7, -7, -7, -7],
        opacity: [1, 1, 1, 0, 0, 0],
    }

    // Open-folder path: hidden behind the closed one → appears at midpoint → bounces to rest
    const openAnimHover = {
        y: [-110, -110, -110, -110, 18, 0],
        scaleX: [0.32, 0.32, 0.32, 0.32, 1.12, 1],
        scaleY: [1.18, 1.18, 1.18, 1.18, 0.92, 1],
        rotate: [-7, -7, -7, -7, 4, 0],
        opacity: [0, 0, 0, 1, 1, 1],
    }

    // Rest state for both folders. Closed is visible (opacity 1), open is
    // hidden (opacity 0). When isHovered flips to false we animate to this
    // single target — framer-motion interpolates from the current state
    // (anywhere along the hover keyframe path) straight back here without
    // snapping to a specific return-keyframe waypoint.
    const closedRest = { y: 0, scaleX: 1, scaleY: 1, rotate: 0, opacity: 1 }
    const openRest = { y: 0, scaleX: 1, scaleY: 1, rotate: 0, opacity: 0 }

    const closedAnim = !hasInteracted
        ? closedRest
        : isHovered
          ? closedAnimHover
          : closedRest

    const openAnim = !hasInteracted
        ? openRest
        : isHovered
          ? openAnimHover
          : openRest

    // Continuous idle float — runs regardless of hover state.
    // Lives on the OUTER wrapper while hover keyframes live on the inner
    // closed/open folder divs. CSS composes the parent's translateY with
    // each child's translateY, so the folder keeps bobbing even mid-hover.
    //
    // Tuned to be obvious at a glance but not distracting: ~3.2s cycle,
    // 10px vertical travel, with a tiny rotation for organic "paper" feel.
    const floatAnimate = prefersReducedMotion
        ? undefined
        : { y: [0, -10, 0], rotate: [0, -1.2, 0] }
    const floatTransition = {
        duration: 3.2,
        repeat: Infinity,
        repeatType: "loop" as const,
        ease: "easeInOut" as const,
    }

    return (
        <motion.div
            // Explicit initial so the float keyframe loop ALWAYS runs on
            // mount, even if some ancestor (an AnimatePresence with
            // initial={false}, a MotionConfig override, etc.) tries to
            // suppress mount-time animations on its descendants.
            // Without this, framer-motion may treat the keyframe array
            // as "already at first frame" and never start the loop.
            initial={{ y: 0, rotate: 0 }}
            animate={floatAnimate}
            transition={floatTransition}
            style={{
                position: "relative",
                width: "100%",
                height: "100%",
                display: "flex",
                alignItems: "center",
                justifyContent: "center",
                willChange: "transform",
            }}
        >
            {/* Closed folder (visible when NOT hovered) */}
            <motion.div
                initial={{ y: 0, scaleX: 1, scaleY: 1, rotate: 0, opacity: 1 }}
                style={{
                    position: "absolute",
                    inset: 0,
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "center",
                    transformOrigin: "50% 85%",
                    willChange: "transform, opacity",
                }}
                animate={closedAnim}
                transition={transition}
            >
                <ClosedFolderSVG folderColor={folderColor} />
            </motion.div>

            {/* Open folder (visible when hovered) */}
            <motion.div
                initial={{ y: 0, scaleX: 1, scaleY: 1, rotate: 0, opacity: 0 }}
                style={{
                    position: "absolute",
                    inset: 0,
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "center",
                    transformOrigin: "50% 85%",
                    willChange: "transform, opacity",
                }}
                animate={openAnim}
                transition={transition}
            >
                <OpenFolderSVG
                    paper1Image={paper1Image}
                    paper2Image={paper2Image}
                    paper1Color={paper1Color}
                    paper2Color={paper2Color}
                    folderColor={folderColor}
                    folderBackColor={folderBackColor}
                    projectKey={projectKey}
                    prefersReducedMotion={prefersReducedMotion}
                />
            </motion.div>
        </motion.div>
    )
}

/* -------------------------------------------------------------------------- */
/*                                SVG: Closed                                  */
/* -------------------------------------------------------------------------- */

function ClosedFolderSVG({ folderColor }: { folderColor: string }) {
    // Unique gradient ID per instance so multiple carousels on a page
    // (and remounts during slide transitions) don't share the same <defs>.
    const uid = useId().replace(/:/g, "")
    const gradId = `closed-grad-${uid}`
    const folderPath =
        "M89.2793 11.0391C90.3128 6.40852 94.9046 3.49219 99.5352 4.52539L204.343 27.917C208.973 28.9505 211.89 33.5422 210.856 38.1729L207.401 53.6494L358.317 87.332C368.902 89.6944 375.567 100.189 373.205 110.773L334.309 285.054C331.946 295.638 321.451 302.304 310.866 299.941L20.3994 235.114C9.81498 232.752 3.14945 222.256 5.51172 211.672L44.4082 37.3916C46.7705 26.8072 57.2661 20.1416 67.8506 22.5039L85.8252 26.5146L89.2793 11.0391Z"

    return (
        <svg
            width="100%"
            height="100%"
            viewBox="0 0 379 305"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            style={{ maxWidth: 300, maxHeight: 240 }}
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
            focusable="false"
        >
            <path
                d={folderPath}
                // Fill via style (not attribute) so the color crossfades
                // smoothly when the project becomes selected/deselected
                // instead of snapping mid-slide. 500ms ease-out-expo to
                // align with the slot slide timing.
                style={{
                    fill: folderColor,
                    transition: "fill 500ms cubic-bezier(0.16, 1, 0.3, 1)",
                }}
            />
            <path
                d={folderPath}
                fill={`url(#${gradId})`}
                style={{ mixBlendMode: "multiply" }}
            />
            {/* Outline: warm cream tint instead of pure white */}
            <path
                d={folderPath}
                stroke={BRAND.creamPaper}
                strokeWidth="7.36362"
            />
            <defs>
                <linearGradient
                    id={gradId}
                    x1="243.741"
                    y1="28.5568"
                    x2="207.23"
                    y2="360.227"
                    gradientUnits="userSpaceOnUse"
                >
                    <stop offset="0.59647" stopColor={BRAND.creamWhite} />
                    <stop offset="0.962107" stopColor={BRAND.terracotta} />
                </linearGradient>
            </defs>
        </svg>
    )
}

/* -------------------------------------------------------------------------- */
/*                                 SVG: Open                                   */
/* -------------------------------------------------------------------------- */

function OpenFolderSVG({
    paper1Image,
    paper2Image,
    paper1Color,
    paper2Color,
    folderColor,
    folderBackColor,
    projectKey,
    prefersReducedMotion,
}: {
    paper1Image?: string
    paper2Image?: string
    paper1Color?: string
    paper2Color?: string
    folderColor: string
    folderBackColor: string
    projectKey: number
    prefersReducedMotion: boolean
}) {
    // Unique IDs per instance so multiple carousels on a page don't clash
    const uid = useId().replace(/:/g, "")
    const p1PatternId = `paper1-pattern-${uid}-${projectKey}`
    const p2PatternId = `paper2-pattern-${uid}-${projectKey}`

    const teal = paper1Color || BRAND.teal
    const blue = paper2Color || BRAND.cornflower
    const grad1Id = `open-grad-1-${uid}-${projectKey}`
    const grad2Id = `open-grad-2-${uid}-${projectKey}`

    return (
        <svg
            width="100%"
            height="100%"
            viewBox="0 0 394 343"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            // overflow: visible so the sparkle motion.g (which scales to
            // 1.18× and rotates) isn't clipped at the viewBox edges. The
            // sparkles sit close to the corners — without this, scaling
            // them up lops off the points that extend beyond x:[0,394] or
            // y:[0,343]. The SVG element's intrinsic size is still
            // governed by maxWidth/maxHeight; only render is unclipped.
            overflow="visible"
            style={{ maxWidth: 340, maxHeight: 280, overflow: "visible" }}
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
            focusable="false"
        >
            <defs>
                {paper1Image && (
                    <pattern
                        id={p1PatternId}
                        patternUnits="objectBoundingBox"
                        patternContentUnits="objectBoundingBox"
                        width="1"
                        height="1"
                    >
                        <image
                            href={paper1Image}
                            x="0"
                            y="0"
                            width="1"
                            height="1"
                            preserveAspectRatio="xMidYMid slice"
                        />
                    </pattern>
                )}
                {paper2Image && (
                    <pattern
                        id={p2PatternId}
                        patternUnits="objectBoundingBox"
                        patternContentUnits="objectBoundingBox"
                        width="1"
                        height="1"
                    >
                        <image
                            href={paper2Image}
                            x="0"
                            y="0"
                            width="1"
                            height="1"
                            preserveAspectRatio="xMidYMid slice"
                        />
                    </pattern>
                )}
                <linearGradient
                    id={grad1Id}
                    x1="234.13"
                    y1="101.101"
                    x2="202.934"
                    y2="390.854"
                    gradientUnits="userSpaceOnUse"
                >
                    <stop offset="0.59647" stopColor={BRAND.creamWhite} />
                    <stop offset="0.962107" stopColor={BRAND.terracotta} />
                </linearGradient>
                <linearGradient
                    id={grad2Id}
                    x1="234.13"
                    y1="101.101"
                    x2="202.934"
                    y2="390.854"
                    gradientUnits="userSpaceOnUse"
                >
                    <stop offset="0.59647" stopColor={BRAND.creamWhite} />
                    <stop offset="0.962107" stopColor={BRAND.terracotta} />
                </linearGradient>
            </defs>

            {/* Back flap (peach) */}
            <path
                d="M106.319 77.6451C107.995 69.0631 115.444 63.6587 122.955 65.574L376.664 130.267C384.176 132.183 388.906 140.692 387.23 149.274L353.255 323.193C351.579 331.775 344.13 337.179 336.619 335.264L82.91 270.571C75.3985 268.656 70.6682 260.146 72.3447 251.564L106.319 77.6451Z"
                // Style-fill + transition so back flap crossfades with
                // the front when the selection state changes.
                style={{
                    fill: folderBackColor,
                    transition: "fill 500ms cubic-bezier(0.16, 1, 0.3, 1)",
                }}
            />
            <path
                d="M100.042 76.0447C102.492 63.5017 113.378 55.6032 124.356 58.4026L378.065 123.095C389.043 125.895 395.957 138.332 393.507 150.875L359.532 324.793C357.082 337.336 346.196 345.236 335.218 342.436L81.5092 277.743C70.5308 274.943 63.6176 262.506 66.0677 249.963L100.042 76.0447ZM122.955 65.574C115.444 63.6587 107.995 69.0631 106.319 77.6451L72.3447 251.564L72.2706 251.966C70.8166 260.41 75.516 268.686 82.91 270.571L336.619 335.264C344.013 337.15 351.346 331.942 353.173 323.593L353.255 323.193L387.23 149.274C388.88 140.826 384.322 132.448 377.014 130.361L376.664 130.267L122.955 65.574Z"
                fill={BRAND.creamPaper}
            />

            {/* Sparkle star left — twinkles on a 2.6s loop, no delay.
                motion.g + transformBox: fill-box scales around the sparkle's
                own bbox center so it pulses in place rather than drifting
                toward the SVG's origin. */}
            <motion.g
                style={{
                    transformBox: "fill-box",
                    transformOrigin: "center",
                    willChange: "transform, opacity",
                }}
                animate={
                    prefersReducedMotion
                        ? undefined
                        : {
                              scale: [1, 1.18, 0.95, 1.08, 1],
                              opacity: [0.9, 1, 0.92, 0.98, 0.9],
                              rotate: [0, 4, -2, 3, 0],
                          }
                }
                transition={{
                    duration: 2.6,
                    repeat: Infinity,
                    repeatType: "loop" as const,
                    ease: "easeInOut" as const,
                }}
            >
                <path
                    d="M94.2655 41.0815C102.294 26.4784 100.64 4.40506 101.415 4.22422C102.191 4.04337 109.538 24.6795 121.311 33.4305C132.879 42.029 151.963 39.9327 152.201 41.2619C152.438 42.5912 132.923 53.326 127.208 66.4343C119.632 83.8108 120.816 101.505 119.912 101.716C119.007 101.927 111.489 78.9455 99.524 70.5123C88.4573 62.7124 71.5157 61.3521 71.2784 60.1352C71.041 58.9183 87.4166 53.5387 94.2655 41.0815Z"
                    fill={BRAND.creamLight}
                />
                <path
                    d="M152.201 41.2619C151.963 39.9327 132.879 42.029 121.311 33.4305C109.538 24.6795 102.191 4.04337 101.415 4.22422C100.64 4.41035 102.293 26.4802 94.2655 41.0815L93.9379 41.6606C86.9092 53.7061 71.0447 58.9373 71.2784 60.1352C71.5157 61.3521 88.4573 62.7124 99.524 70.5123C111.396 78.8802 118.89 101.572 119.89 101.717L119.912 101.716C120.802 101.506 119.669 84.3582 126.859 67.2491L127.208 66.4343C132.879 53.4273 152.137 42.7573 152.202 41.2944L152.201 41.2619ZM155.821 40.4178C156.096 41.959 155.566 43.1278 155.366 43.5225C155.12 44.0103 154.838 44.3635 154.675 44.556C154.335 44.9575 153.945 45.3083 153.643 45.5666C153.007 46.1109 152.138 46.7651 151.211 47.4527C149.285 48.8809 146.773 50.6956 144.067 52.8785C138.512 57.3605 132.92 62.7999 130.515 68.3161C126.976 76.4332 125.455 84.6974 124.721 91.064C124.354 94.2446 124.187 96.9048 124.051 98.8879C123.986 99.8286 123.92 100.758 123.83 101.465C123.788 101.791 123.713 102.307 123.561 102.824C123.488 103.072 123.331 103.552 123.022 104.059C122.73 104.537 121.992 105.539 120.651 105.852C118.909 106.258 117.706 105.153 117.501 104.966C117.124 104.621 116.867 104.258 116.745 104.078C116.476 103.682 116.241 103.236 116.067 102.891C115.698 102.161 115.239 101.147 114.744 100.051C113.721 97.7842 112.366 94.7677 110.682 91.4966C107.236 84.8067 102.746 77.7425 97.5844 74.1046C92.5927 70.5863 86.0875 68.4169 80.5212 66.9711C77.7457 66.2502 75.3736 65.7485 73.4936 65.3079C72.6041 65.0995 71.7427 64.8858 71.0731 64.663C70.7566 64.5577 70.3122 64.3953 69.8806 64.1524C69.6686 64.033 69.3113 63.8139 68.9458 63.4563C68.6168 63.1345 67.9273 62.357 67.6729 61.0538C67.3869 59.5875 67.829 58.423 68.134 57.841C68.4347 57.267 68.7877 56.8845 68.9801 56.6908C69.3754 56.2928 69.8046 55.9968 70.0761 55.8185C70.6649 55.4319 71.4499 55.0019 72.2266 54.5819C73.8741 53.6909 76.0022 52.5723 78.3506 51.1146C83.1265 48.1501 88.2341 44.1175 91.1376 38.8365C94.6989 32.3589 96.2183 23.9644 96.8866 16.7973C97.216 13.2651 97.3298 10.15
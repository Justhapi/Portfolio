                    delay: 0.4,
                }}
            >
                <path
                    d="M21.3957 172.324C25.7129 155.799 18.9508 135.036 19.6556 134.625C20.3605 134.214 32.2719 151.852 45.6647 156.686C58.8242 161.436 76.722 153.584 77.2621 154.792C77.8022 156.001 61.5116 172.308 59.0738 186.685C55.8421 205.744 61.1259 222.432 60.3036 222.912C59.4813 223.392 46.8567 203.545 33.3531 199.075C20.8635 194.942 4.22079 198.809 3.70716 197.709C3.19352 196.609 17.7129 186.42 21.3957 172.324Z"

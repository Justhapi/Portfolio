                    fill={BRAND.peachShade}
                />
            </motion.g>

            {/* Blue paper (sneak peek #2) */}
            <path
                d="M355.972 94.7499C361.427 97.3797 363.983 104.563 361.681 110.795L321.076 220.731C318.774 226.963 312.486 229.883 307.032 227.253L212.124 181.496C206.67 178.866 204.114 171.682 206.416 165.45L247.021 55.5146C249.323 49.2828 255.61 46.3627 261.065 48.9925L355.972 94.7499Z"

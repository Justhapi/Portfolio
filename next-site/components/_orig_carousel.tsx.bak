                fill={BRAND.creamPaper}
            />

            {/* Sparkle star right — twinkles on a 2.9s loop with its own
                phase offset. Gentlest amplitude of the three so the eye
                doesn't read it as the focal point. */}
            <motion.g
                style={{
                    transformBox: "fill-box",
                    transformOrigin: "center",
                    willChange: "transform, opacity",
                }}
                animate={
                    prefersReducedMotion
                        ? undefined
                        : {

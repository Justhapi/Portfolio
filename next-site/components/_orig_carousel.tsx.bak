                />
                <path
                    d="M77.2621 154.792C76.722 153.584 58.8242 161.436 45.6647 156.686C32.2719 151.852 20.3605 134.214 19.6556 134.625C18.9527 135.041 25.7124 155.802 21.3957 172.324L21.2156 172.982C17.2632 186.737 3.20155 196.626 3.70716 197.709C4.22079 198.809 20.8635 194.942 33.3531 199.075C46.7521 203.51 59.2856 223.085 60.2824 222.92L60.3036 222.912C61.1121 222.437 56.0057 206.26 58.9281 187.577L59.0738 186.685C61.4928 172.419 77.5509 156.253 77.2713 154.823L77.2621 154.792ZM80.5524 152.873C81.1786 154.274 80.9412 155.562 80.8416 156.003C80.7186 156.548 80.5298 156.975 80.4176 157.21C80.1836 157.701 79.8903 158.158 79.6597 158.499C79.1737 159.218 78.4902 160.114 77.7576 161.06C76.2362 163.025 74.241 165.541 72.1448 168.471C67.8412 174.488 63.7262 181.438 62.7003 187.488C61.1907 196.391 61.6606 204.819 62.4434 211.178C62.8344 214.355 63.2968 216.969 63.6298 218.921C63.7879 219.848 63.9419 220.763 64.02 221.472C64.0561 221.799 64.1046 222.319 64.0788 222.863C64.0664 223.125 64.028 223.636 63.8486 224.219C63.6796 224.768 63.2026 225.959 61.9839 226.67C60.401 227.594 58.983 226.897 58.7417 226.78C58.2973 226.563 57.9645 226.292 57.8048 226.155C57.4534 225.856 57.1221 225.498 56.8738 225.219C56.3476 224.628 55.6678 223.791 54.9346 222.886C53.4177 221.015 51.4063 218.522 49.0172 215.885C44.1312 210.492 38.1504 205.058 32.3252 203.13C26.6917 201.265 19.9156 201.163 14.2136 201.471C11.3705 201.624 8.96736 201.866 7.05277 202.016C6.14688 202.087 5.26677 202.144 4.56946 202.134C4.23984 202.129 3.77357 202.109 3.30086 202.007C3.06859 201.956 2.67305 201.854 2.2371 201.622C1.84475 201.412 0.99834 200.874 0.448116 199.696C-0.170775 198.37 -0.0173667 197.113 0.14019 196.459C0.295591 195.814 0.546138 195.338 0.686205 195.092C0.973947 194.588 1.31817 194.171 1.53807 193.917C2.01487 193.364 2.67062 192.71 3.32068 192.068C4.69952 190.706 6.48819 188.978 8.40969 186.855C12.3175 182.539 16.2949 177.093 17.8561 171.117C19.7711 163.787 19.2698 155.234 18.2357 148.124C17.7261 144.62 
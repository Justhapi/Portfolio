                style={{
                    fill: folderColor,
                    transition: "fill 500ms cubic-bezier(0.16, 1, 0.3, 1)",
                }}
            />
            <path
                d="M69.6582 90.2099C69.3903 87.3367 69.3869 82.8338 71.5341 83.1686L168.09 104.273C170.237 104.607 172.274 108.007 172.274 112.891L177.912 173.794C177.626 176.31 177.362 181.885 175.215 181.55L88.1935 160.867C86.0464 160.532 83.4954 156.201 83.7812 153.685L69.6582 90.2099Z"
                fill={`url(#${grad2Id})`}
                style={{ mixBlendMode: "multiply" }}
            />

            {/* White outline (drawn as filled shape) — tinted cream */}
            <path
                d="M65.2975 79.1008C66.8694 76.8815 69.3399 75.522 72.1324 75.8507L72.4037 75.8878L72.5743 75.9141L72.7423 75.9511L169.226 97.0381C172.788 97.712 175.195 100.568 176.524 103.136C177.907 105.809 178.64 109.04 178.7 112.438L179.199 117.831L315.234 146.458L315.31 146.474L315.387 146.493C320.72 147.77 325.107 151.076 328.033 156.202C330.771 161 331.948 166.883 332.019 173.175L353.408 323.848L353.111 325.276C350.554 337.566 339.495 344.629 328.908 342.094L75.3524 281.396L75.2194 281.364L75.0872 281.326C70.3171 279.941 65.4436 278.21 61.5418 274.259C57.5011 270.167 55.292 264.559 53.9059 257.421L19.7168 109.657L19.6818 109.467C19.0337 105.917 18.4606 102.846 18.1532 100.475C17.9969 99.269 17.8743 97.992 17.8735 96.7506C17.8727 95.5553 17.9792 93.9181 18.5746 92.2366C19.2451 90.343 20.4382 88.6791 22.1418 87.589C23.6667 86.6134 25.1924 86.362 26.2532 86.2929C28.1974 86.1663 30.4922 86.5894 32.3631 86.9341L32.4339 86.9468L32.5038 86.9624L63.7621 93.5395L63.3109 91.5106L63.2623 90.9882C63.1099 89.3536 62.9593 86.6566 63.3663 84.147C63.5587 82.9615 64.0074 80.9223 65.2975 79.1008ZM71.5341 83.1686C69.3869 82.8338 69.3903 87.3367 69.6582 90.2099L72.4685 102.843L31.3391 94.1888C23.0305 92.6579 23.2959 93.2703 25.9783 107.967L60.1541 255.671C62.6306 268.598 67.249 271.468 76.6714 274.204L330.227 334.902C337.617 336.671 344.946 331.785 346.771 323.951L346.853 323.576L325.592 173.794C325.592 162.776 321.7 155.705 314.418 153.773L314.068 153.685L173.307 124.063L172.274 112.891C172.274 108.007 170.237 104.607 168.09 104.273L71.5341 83.1686Z"
                fill={BRAND.creamPaper}
            />
        </svg>
    )
}

/* -------------------------------------------------------------------------- */
/*                          Mini tracker folder icon                           */
/* -------------------------------------------------------------------------- */

function MiniFolder({
    active,
    activeColor,
    inactiveColor,
    paletteIndex,
}: {
    active: boolean
    activeColor: string
    inactiveColor: string
    paletteIndex: number
}) {
    // Each project has a permanent hue identity. The active tab uses a
    // BRIGHTER sibling of that same hue (dark plum → light plum, ochre →
    // light ochre, etc.) instead of swapping to a single shared cream.
    // This keeps the row legible as a stable lineup of N projects while
    // still making the selected one pop visually.
    //
    // activeColor / inactiveColor props remain as fallbacks for projects
    // beyond the 5-slot palette OR when the user explicitly overrides
    // them in the Framer inspector.
    const palette = [
        BRAND.ochre, // project 0 — dark muted gold
        BRAND.terracotta, // project 1 — warm brick
        BRAND.plum, // project 2 — soft purple
        BRAND.teal, // project 3
        BRAND.cornflower, // project 4
    ]
    const lightPalette = [
        BRAND.ochreLight,
        BRAND.terracottaLight,
        BRAND.plumLight,
        BRAND.tealLight,
        BRAND.cornflowerLight,
    ]
    const slot = paletteIndex % palette.length
    const projectColor = palette[slot] || inactiveColor
    const projectColorActive = lightPalette[slot] || activeColor
    const color = active ? projectColorActive : projectColor

    return (
        <svg
            width="32"
            height="26"
            viewBox="0 0 32 26"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
        >
            <path
                d="M3 4 Q3 1 6 1 L11 1 L13 4 L26 4 Q29 4 29 7 L29 21 Q29 24 26 24 L6 24 Q3 24 3 21 Z"
                fill={color}
                stroke={BRAND.creamPaper}
                strokeWidth="1.6"
                strokeLinejoin="round"
            />
        </svg>
    )
}


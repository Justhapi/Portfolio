                fill={BRAND.creamPaper}
            />

            {/* Sparkle star bottom-left — twinkles on a 3.4s loop.
                Different duration / amplitudes than sparkles 1 & 3 so the
                three never re-sync after the first cycle: organic shimmer. */}
            <motion.g
                style={{
                    transformBox: "fill-box",
                    transformOrigin: "center",
                    willChange: "transform, opacity",
                }}
                animate={
                    prefersReducedMotion
                        ? undefined
